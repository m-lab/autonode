# Package-owned constants for the mlab-node services. Installed under
# /usr/lib/mlab (not a conffile) so package upgrades can change them without
# conffile merge prompts. The units load this file before the operator-edited
# /etc/mlab/mlab-node.env, so values set there take precedence if you must
# override these.
PROJECT=mlab-autojoin
LOCATE_URL=locate.measurementlab.net
AUTH_URL=auth.mlab-oti.measurementlab.net
