# Configuration for the M-Lab node (mlab-node) services.
# This file is sourced by the systemd units as an EnvironmentFile. Edit the
# values below to match your deployment, then start the stack with:
#   systemctl start mlab-node.target
#
# The API key is kept separately in /etc/mlab/api-key.env.

# ORGANIZATION is the organization name assigned by M-Lab to your deployment.
ORGANIZATION=

# IATA is the 3-letter, lowercase IATA code of the nearest international
# airport. Estimate it from your latitude/longitude:
# https://autojoin-dot-mlab-autojoin.appspot.com/autojoin/v0/lookup?lat=&lon=
IATA=

# PROBABILITY is the probability (0-1) that this node is selected by M-Lab's
# load balancer. Default is 0.1 (10%).
PROBABILITY=0.1

# INTERFACE_NAME is the network interface to which INTERFACE_MAXRATE applies.
INTERFACE_NAME=

# UPLINK is the uplink speed, an integer followed by "g" (e.g. "1g", "10g",
# "25g"). Minimum is 1g; 10g or greater is recommended.
UPLINK=

# INTERFACE_MAXRATE is the rate (bit/s) above which ndt-server refuses new
# connections. Recommended: 1G -> 150000000, 10G -> 7000000000.
INTERFACE_MAXRATE=

# IPV4 is the external IPv4 address this node is reachable at. Required.
IPV4=

# IPV6 is the external IPv6 address this node is reachable at. Optional; set it
# to make the node accessible over IPv6.
IPV6=

# TYPE is "physical" (bare-metal dedicated to M-Lab) or "virtual" (a VM).
TYPE=

# ### Static configuration. Do NOT change these. ###
PROJECT=mlab-autojoin
LOCATE_URL=locate.measurementlab.net
AUTH_URL=auth.mlab-oti.measurementlab.net
