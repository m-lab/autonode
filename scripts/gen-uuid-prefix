#!/bin/sh
# Generate the ndt-server UUID prefix from the kernel boot time and hostname.
# Runs once per boot (btime only changes across reboots). Replaces the inline
# /bin/sh entrypoint the ndt-server container used under docker-compose.
set -eu

prefix_file="/var/lib/mlab/schemas/uuid.prefix"
btime="$(awk '/^btime / {print $2}' /proc/stat)"
printf '%s_%s' "$(hostname)" "${btime}" > "${prefix_file}"
