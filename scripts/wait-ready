#!/bin/sh
# Poll the register-node readiness endpoint until it reports ready. This gates
# every dependent service on a successful node registration (replacing the
# docker-compose `depends_on: condition: service_healthy`).
set -eu

url="${1:-http://localhost:8001/ready}"
for _ in $(seq 1 60); do
  if curl -fsS -o /dev/null "${url}"; then
    exit 0
  fi
  sleep 2
done
echo "mlab-node: ${url} did not become ready in time" >&2
exit 1
