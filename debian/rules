#!/usr/bin/make -f

%:
	dh $@

# Extract the component binaries from the pinned container images (via skopeo,
# no Docker daemon) unless they are already staged. This runs as the package
# "build" step; the binaries are then installed via debian/mlab-node.install.
override_dh_auto_build:
	if [ ! -e binaries/ndt-server ]; then ./.build/fetch-binaries.sh; fi

# Install the target so it is enabled (auto-start on boot) but not started at
# install time - the operator must configure /etc/mlab/*.env first. The other
# units carry no [Install] section and are pulled in by the target, so they are
# only registered for daemon-reload, not enabled or started individually.
override_dh_installsystemd:
	dh_installsystemd --no-start --no-enable
	dh_installsystemd --no-start --name=mlab-node mlab-node.target

# The shipped binaries are M-Lab's released, tested artifacts; do not strip or
# otherwise rewrite them.
override_dh_strip:
override_dh_dwz:

# scamper and the static Go binaries are resolved normally. generate-schemas-ndt7
# is the lone musl-linked binary; dpkg-shlibdeps has no shlibs info for musl, so
# exclude it here - its runtime requirement is declared as Depends: musl.
override_dh_shlibdeps:
	dh_shlibdeps -Xgenerate-schemas-ndt7
