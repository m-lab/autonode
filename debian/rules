#!/usr/bin/make -f

%:
	dh $@

# dh_installsysusers is not part of the default dh sequence on debhelper 13.14
# (unlike dh_installtmpfiles), so invoke it explicitly to create the mlab-node
# system user from debian/mlab-node.sysusers. Running it here (after dh_install,
# before dh_installtmpfiles) orders the postinst so the user exists before the
# tmpfiles directories are chowned to it.
execute_after_dh_install:
	dh_installsysusers

# Build the component binaries from source at the pinned upstream release
# tags unless they are already staged. This runs as the package "build" step;
# the binaries are then installed via debian/mlab-node.install.
override_dh_auto_build:
	if [ ! -e binaries/ndt-server ]; then ./.build/build-binaries.sh; fi

# Install the target so it is enabled (auto-start on boot) but not started at
# install time - the operator must configure /etc/mlab/*.env first. The other
# units carry no [Install] section and are pulled in by the target, so they are
# only registered for daemon-reload, not enabled or started individually.
override_dh_installsystemd:
	dh_installsystemd --no-start --no-enable
	dh_installsystemd --no-start --name=mlab-node mlab-node.target

# The shipped binaries are built from M-Lab's released, tested sources; do
# not strip or otherwise rewrite them.
override_dh_strip:
override_dh_dwz:
